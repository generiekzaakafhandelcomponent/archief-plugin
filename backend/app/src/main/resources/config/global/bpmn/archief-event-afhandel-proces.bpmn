<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_0wh3h0k"
                  targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.34.0">
  <bpmn:collaboration id="Collaboration_134xj6j" isClosed="false">
    <bpmn:participant id="Participant_1ry53rc" processRef="archief-event-afhandel-proces"/>
  </bpmn:collaboration>
  <bpmn:process id="archief-event-afhandel-proces" name="Archief event afhandel process" processType="None"
                isClosed="false" isExecutable="true">
    <bpmn:extensionElements>
      <camunda:properties>
        <camunda:property name="systemProcess" value="true"/>
      </camunda:properties>
    </bpmn:extensionElements>
    <bpmn:startEvent id="StartEvent_1" name="Archief notification" camunda:asyncAfter="true">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="link-process-to-document" name="Link process to document" camunda:asyncAfter="true"
                      implementation="##WebService" camunda:expression="${true}">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="delete-document" name="Delete document" camunda:asyncAfter="true"
                      implementation="##WebService" camunda:expression="${true}">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_1">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="link-process-to-document"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="link-process-to-document" targetRef="delete-document"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="delete-document" targetRef="EndEvent_1"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_134xj6j">
      <bpmndi:BPMNShape id="Participant_1ry53rc_di" bpmnElement="Participant_1ry53rc" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="680" height="390"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_start_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="232" y="242" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="224" y="285" width="53" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_link_di" bpmnElement="link-process-to-document">
        <dc:Bounds x="340" y="220" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_delete_di" bpmnElement="delete-document">
        <dc:Bounds x="520" y="220" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_end_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="702" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="268" y="260"/>
        <di:waypoint x="340" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="260"/>
        <di:waypoint x="520" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="620" y="260"/>
        <di:waypoint x="702" y="260"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
