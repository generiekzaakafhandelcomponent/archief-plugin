### 1. Get zaken (ordered by most recent) - copy the 'zaakUrl' from the first result
GET {{openzaakHost}}/zaken/api/v1/zaken?ordering=-identificatie
Accept-Crs: EPSG:4326
Content-Crs: EPSG:4326
Authorization: Bearer {{openzaakToken}}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200 but got " + response.status);
    });
    client.global.set("zaakUrl", response.body.results[0].url);
    client.log("zaakUrl: " + client.global.get("zaakUrl"));
%}

### 2. Send archief notification using the zaakUrl from step 1
POST {{notificatiesHost}}/api/v1/notificaties
Content-Type: application/json
Authorization: Bearer {{notificatiesToken}}

{
  "kanaal": "zaakdossier",
  "hoofdObject": "{{zaakUrl}}",
  "resource": "zaak",
  "resourceUrl": "{{zaakUrl}}",
  "actie": "archive",
  "aanmaakdatum": "2025-09-08T20:08:53.115418+02:00",
  "kenmerken": {}
}

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 201, "Expected 201 but got " + response.status);
    });
%}
